<style>
  section { display: flex; flex-direction: column; align-items: center; }

  .hero-bg {
    width: 100%;
    background: linear-gradient(135deg, #3D2400 0%, #7A4A0A 40%, #E0A020 100%);
    color: #fff;
    display: flex;
    justify-content: center;
    padding: 4rem 1.25rem;
  }

  .hero-content { max-width: 720px; display: flex; flex-direction: column; gap: 0.75rem; }

  .section-label {
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; opacity: 0.6;
  }

  .hero-content h2 {
    font-size: 2.5rem; font-weight: 600; letter-spacing: -0.02em;
    margin: 0; line-height: 1.15;
  }

  .hero-content .lede {
    font-size: 1.125rem; line-height: 1.65; margin: 0; opacity: 0.9; max-width: 500px;
  }

  .content {
    max-width: 680px; display: flex; flex-direction: column;
    gap: 1.25rem; padding: 4rem 1.25rem;
  }

  .action-panel {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem;
    border: 1px solid var(--neutral-200);
    border-radius: 12px;
    background: #FAFAFA;
  }

  .panel-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    background: #FFF5E6;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .panel-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .panel-body h3 {
    font-size: 1.125rem; font-weight: 600; color: var(--neutral-900);
    margin: 0;
  }

  .panel-body p {
    font-size: 0.9rem; line-height: 1.5; color: var(--neutral-500);
    margin: 0; max-width: 480px;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.2rem;
    background: linear-gradient(135deg, #E0760E, #C0650A);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.12s, box-shadow 0.12s;
    box-shadow: 0 2px 6px rgba(192, 101, 10, 0.25);
    align-self: flex-start;
  }

  .action-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(192, 101, 10, 0.35);
  }

  .action-btn:active {
    transform: translateY(0);
  }

  .callout {
    display: flex; gap: 0.75rem; align-items: flex-start;
    padding: 1rem 1.25rem; background: #FFF5E6; border: 1px solid #FFD699;
    border-radius: 10px; font-size: 0.9375rem; line-height: 1.5; color: #7A3A00;
  }

  .callout svg { flex-shrink: 0; margin-top: 2px; }
 
ul.share-buttons{
  list-style: none;
  padding: 0;
}

ul.share-buttons li{
  display: inline;
}

ul.share-buttons .sr-only{
  position: absolute;
  clip: rect(1px 1px 1px 1px);
  clip: rect(1px, 1px, 1px, 1px);
  padding: 0;
  border: 0;
  height: 1px;
  width: 1px;
  overflow: hidden;
}

ul.share-buttons img{
  width: 32px;
}

</style>
