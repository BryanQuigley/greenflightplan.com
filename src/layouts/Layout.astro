---
import '/styles/reset.css';
import 'svooltip/styles.css';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<meta name="description" content="Tax leaded avgas, electrify short-haul flights, scale SAF for long haul — an interactive roadmap to clean aviation." />
		<meta name="og:title" content={title} />
		<meta name="og:description" content="Tax leaded avgas, electrify short-haul flights, scale SAF for long haul — an interactive roadmap to clean aviation." />
    <meta property="og:image" content="https://examplesite.com/social-card.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="https://examplesite.com" />
    <meta property="twitter:url" content="https://examplesite.com" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content="Tax leaded avgas, electrify short-haul flights, scale SAF for long haul — an interactive roadmap to clean aviation." />
		<meta name="twitter:image" content="https://examplesite.com/social-card.jpg" />
		<link href="https://actionnetwork.org/css/style-embed-v3.css" rel="stylesheet" type="text/css" />
	</head>
	<body>
		<div class="demo-banner">Work in Progress &mdash; Demo only - some data/words are not correct yet</div>
		<slot />
	</body>
</html>
<style is:global >
	
	:root {
		--accent: 124, 58, 237;
		--accent-gradient: linear-gradient(45deg, rgb(var(--accent)), #da62c4 30%, white 60%);
		
		--neutral-900: #18181B;
		--neutral-700: #3F3F46;
		--neutral-500: #71717A;
		--neutral-400: #A1A1AA;
		--neutral-300: #D4D4D8;
		--neutral-200: #E4E4E7;
		--neutral-50: #FAFAFA;

		--primary-direct: #3876FF;

		--svooltip-bg: var(--neutral-700);
		--svooltip-text: #FFF;
		--svooltip-padding: 5px 7px;
		--svooltip-weight: 400;
		--svooltip-text-size: 14px;
		--svooltip-shadow: none;
		--svooltip-arrow-size: 0px;
	}

	html {
		font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		background-color: #F6F6F6;
		font-size: 14px;
		font-feature-settings: "ss01" on, "tnum" on;
	}

	.svooltip {
		max-width: 20em;
	}

	.svooltip-content {
		display: flex;
		flex-direction: column;
		justify-items: center;
		gap: .25em;
	}

	.svooltip-content img {
		max-width: 200px;
	}

	sub {
		vertical-align: sub;
		font-size: .6em;
		font-weight: 500;
	}

	.demo-banner {
		background: #F5D94A;
		color: #3D2A00;
		text-align: center;
		padding: 0.5rem 1rem;
		font-size: 0.8125rem;
		font-weight: 600;
		letter-spacing: 0.04em;
	}

</style>
